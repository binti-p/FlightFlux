# Copy this file to .env and fill in actual AWS resource endpoints after
# Person 1 provisions infrastructure. Never commit the .env file.

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# ── S3 ───────────────────────────────────────────────────────────────────────
S3_BUCKET_RAW=flightdelay-raw
S3_BUCKET_PROCESSED=flightdelay-processed
S3_BUCKET_MODELS=flightdelay-models

# ── Kafka / MSK ───────────────────────────────────────────────────────────────
# Find bootstrap servers in: MSK console → cluster → Client information
KAFKA_BOOTSTRAP_SERVERS=b-1.xxxxx.kafka.us-east-1.amazonaws.com:9092
KAFKA_TOPIC_RAW=flights-raw
KAFKA_TOPIC_ENRICHED=flights-enriched

# ── MongoDB ───────────────────────────────────────────────────────────────────
# MongoDB running on EC2: mongodb://<EC2-private-IP>:27017
# Or DocumentDB endpoint if using managed service
MONGODB_URI=mongodb://[EC2-IP]:27017
MONGODB_DB=flightdelay

# ── Redis / ElastiCache ───────────────────────────────────────────────────────
# Find endpoint in: ElastiCache console → cluster → Primary endpoint
REDIS_HOST=[elasticache-endpoint].cache.amazonaws.com
REDIS_PORT=6379
REDIS_TTL_SECONDS=60

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
MODEL_S3_PATH=s3://flightdelay-models/v1/

# ── OpenSky ───────────────────────────────────────────────────────────────────
OPENSKY_BASE_URL=https://opensky-network.org/api
OPENSKY_POLL_INTERVAL_SECONDS=15

# ── EMR ───────────────────────────────────────────────────────────────────────
# Cluster ID used when submitting Spark jobs via aws emr add-steps
EMR_CLUSTER_ID=j-XXXXXXXXXXXXX
