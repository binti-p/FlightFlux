# Keep True for frontend-only demo. Set False when FastAPI is running.
USE_MOCK=True

# Existing FlightFlux FastAPI service usually runs on port 8000.
FLIGHTFLUX_API_BASE_URL=http://localhost:8000

# Existing repo endpoints.
FLIGHTFLUX_HEALTH_ENDPOINT=/health
FLIGHTFLUX_PREDICT_ENDPOINT=/predict

# Add this endpoint to the repo API using backend_integration/fastapi_live_adapter.py.
FLIGHTFLUX_LIVE_FLIGHTS_ENDPOINT=/live-flights
FLIGHTFLUX_SUMMARY_ENDPOINT=/metrics/summary

REFRESH_INTERVAL_MS=15000
REQUEST_TIMEOUT_SECONDS=5
MAX_PREDICT_CALLS_PER_REFRESH=60
